Grammar

    0 $accept: programme $end

    1 programme: MC_BEGINPROJECT IDF ';' MC_SETUP ':' declarations MC_RUN ':' '{' instructions '}' MC_ENDPROJECT ';'

    2 declarations: /* empty */
    3             | declarations declaration

    4 declaration: MC_DEFINE corps_declaration ';'
    5            | MC_CONST IDF ':' type '=' expression ';'

