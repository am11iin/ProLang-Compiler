   24 loop_stmt: MC_LOOP MC_WHILE '(' expression ')' '{' instructions '}' MC_ENDLOOP ';'
   25          | MC_FOR IDF MC_IN expression MC_TO expression '{' instructions '}' MC_ENDFOR ';'

   26 expression: expression '+' expression
   27           | expression '-' expression
